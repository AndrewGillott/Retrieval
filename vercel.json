{
  "functions": {
    "api/Homework.js": {
      "maxDuration": 60
    },
    "api/generate.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/homework/:id",
      "destination": "/homework.html"
    },
    {
      "source": "/(?!api/).*",
      "destination": "/index.html"
    }
  ]
}
